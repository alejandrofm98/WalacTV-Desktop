{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "WalacTV",
  "version": "1.1.1",
  "identifier": "com.walactv.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "WalacTV",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://iptv.walerike.com https:; img-src 'self' https://image.tmdb.org https:* data:; media-src 'self' https: http: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnRzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCOEJGNkY5N0YwNUVGQ0IKUldUTDd3Vi8rZmFMcTBHMDIxTjdKa09iNjFhU2src3ZMVDV2Zi8zT0IzZmNGZCsyb1ArQTIvVG0K",
      "endpoints": ["https://github.com/alejandrofm98/walactv-desktop/releases/latest/download/latest.json"]
    }
  }
}
